# Altune API — local environment template.
# Copy to .env (gitignored) and fill in actual values for local dev.

# App
ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins for the mobile dev client
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Database (placeholder — set when persistence ADR lands)
# DATABASE_URL=postgresql+asyncpg://altune:password@localhost:5432/altune

# Sentry (placeholder — set when observability ADR lands)
# SENTRY_DSN=
