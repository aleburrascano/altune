# Altune API — local environment template.
# Copy to .env (gitignored) and fill in actual values for local dev.

# App
ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins for the mobile dev client
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Database — per ADR-0003 (SQLAlchemy 2.0 async + asyncpg).
# Matches the credentials in docker-compose.yml at the repo root.
# DATABASE_URL=postgresql+asyncpg://altune:altune_dev@localhost:5432/altune
DATABASE_URL=postgresql+asyncpg://altune:altune_dev@localhost:5432/altune
SUPABASE_PROJECT_URL=https://ellvexundmgvbbfqbzau.supabase.co
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWT_JWKS_URL=https://ellvexundmgvbbfqbzau.supabase.co/auth/v1/.well-known/jwks.json

# Multi-tenancy — per ADR-0004. Single hardcoded user for v1.
# Required in dev/test; forbidden in production (startup guard refuses).
# HARDCODED_USER_ID=00000000-0000-0000-0000-000000000001

# Audio acquisition — per acquire-track spec.
# Local dev: relative or absolute path to a folder for downloaded audio.
# Production: /mnt/oci-music (NFS mount on the OCI instance).
MUSIC_DIR=.data/music
# Path to ffmpeg bin directory. Omit if ffmpeg is on system PATH (e.g. Linux prod).
# FFMPEG_LOCATION=/path/to/ffmpeg/bin

# Sentry (placeholder — set when observability ADR lands)
# SENTRY_DSN=

# Discovery — per ADR-0007 (discover-music-v1). Provider credentials
# + cache infra. Required at app startup; missing values fail-fast via
# Settings model_validator.

# Redis cache (used by discovery query cache; future cross-cutting use OK).
# Matches the redis service in docker-compose.yml at the repo root.
REDIS_URL=redis://localhost:6379/0

# MusicBrainz — User-Agent MUST include a contact form URL or email per
# https://musicbrainz.org/doc/MusicBrainz_API/Rate_Limiting.
# Without this, MusicBrainz throttles to 1 req/s; with a registered UA,
# rate budget is ~50 req/s.
MUSICBRAINZ_USER_AGENT=altune/0.1 ( mailto:burrascanoale@gmail.com )

# SoundCloud — no API key required. Per ADR-0007 (revised), altune
# uses yt-dlp's scsearch: prefix to extract SoundCloud search results
# without going through SoundCloud's Developer API (which now requires
# an Artist Pro account, blocking solo-dev access). yt-dlp is added
# as a runtime dep; no env vars needed for SC.

# Last.fm — API key from https://www.last.fm/api/account/create.
# v1 uses search endpoints only (no signed write methods).
LASTFM_API_KEY=
# Reserved for future write endpoints; v1 search is unsigned.
# LASTFM_SHARED_SECRET=
