# Environment
ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Database (Supabase or local Postgres)
# Local dev:  postgresql://altune:altune_dev@localhost:5432/altune?sslmode=disable
# Supabase:   postgresql://postgres.[ref]:[pw]@...pooler.supabase.com:5432/postgres?sslmode=require
#             Use session-mode pooler (port 5432), NOT transaction mode (port 6543).
DATABASE_URL=postgresql://altune:altune_dev@localhost:5432/altune?sslmode=disable

# Supabase Auth (JWKS only — HS256 not supported)
SUPABASE_PROJECT_URL=https://<ref>.supabase.co
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWT_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# Public client key — used by the Mission Control sign-in page.
SUPABASE_ANON_KEY=

# Redis (optional — caches degrade gracefully when unavailable)
REDIS_URL=redis://localhost:6379/0

# Discovery providers (all optional — disabled when unset)
MUSICBRAINZ_USER_AGENT=altune/0.1 ( mailto:dev@altune.test )
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
FANARTTV_API_KEY=
GENIUS_ACCESS_TOKEN=
DISCOGS_TOKEN=
YOUTUBE_API_KEY=

# Discovery pipeline cutover (plan 003 strangler). false = audited v1 (default);
# true routes the search surface to the rebuilt v2 pipeline. Flip only after the
# top-K eval shows v2 >= v1 (--pipeline v2 vs v1); rollback is setting it back.
DISCOVERY_V2_SEARCH=false


# OCI Object Storage (S3-compatible)
OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_ACCESS_KEY=
OCI_S3_SECRET_KEY=
OCI_S3_BUCKET=altune-audio
OCI_S3_REGION=ca-montreal-1

# Local audio storage fallback
MUSIC_DIR=

# Audio acquisition tools
FFMPEG_LOCATION=
YTDLP_COOKIE_FILE=
YTDLP_JS_RUNTIME=node

# Mission Control — operator console at /admin (fail-closed: console is denied
# to everyone unless OPERATOR_USER_ID is set to your Supabase user id).
OPERATOR_USER_ID=
# Alert push channel — ntfy topic URL. Empty = alerts logged only. Use a
# non-guessable random topic, e.g. https://ntfy.sh/altune-<random>.
ALERT_NTFY_URL=
# Discovery-eval meter. OFF by default — a live run hits real provider APIs and
# shares quota with user traffic. Leave false until the live runner is wired.
EVAL_METER_ENABLED=false
