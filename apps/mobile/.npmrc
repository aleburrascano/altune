# Force nested install for this workspace so jest-expo and react-native
# end up in the same node_modules tree. Without this, npm hoists jest-expo
# to the workspace root while react-native stays at apps/mobile/node_modules,
# and jest-expo's internal `require('react-native/jest-preset')` can't
# resolve — see jest.config.js for the symptom we're working around.
install-strategy=nested
legacy-peer-deps=true
