# Standard React Native install pragma. The RN/Expo ecosystem ships tight,
# frequently-out-of-sync peer ranges (e.g. react-test-renderer pinning an
# exact react patch); legacy-peer-deps lets npm resolve them the way Expo's
# own tooling does. This is NOT the old workspace hack — apps/mobile is a
# standalone package now (ADR-0016), so there is no install-strategy here.
legacy-peer-deps=true
